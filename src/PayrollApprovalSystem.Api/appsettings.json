{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },

  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/payroll-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },

  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  "JwtSettings": {
    "Key": "",
    "Issuer": "PayrollSystem",
    "Audience": "PayrollUsers",
    "DurationInMinutes": 60
  },

  "AllowedHosts": "*"
}
